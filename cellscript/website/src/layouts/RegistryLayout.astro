---
import "../styles/global.css";
import "../styles/registry.css";
import SiteHeader from "../components/SiteHeader.astro";
import { ClientRouter } from "astro:transitions";
import { defaultLocale, translations } from "../i18n/translations";
import { registrySections } from "../lib/registry";

interface Props {
  title: string;
  description: string;
  // Optional i18n keys (under the `registry.*` namespace) for the page
  // heading and description, so the layout can re-render them on locale
  // change. Omit for pages whose heading is a dynamic identifier (e.g. a
  // package coordinate) that should not be localized.
  headingKey?: string;
  descriptionKey?: string;
  active: "search" | "submit" | "manage" | "package";
}

const { title, description, headingKey, descriptionKey, active } = Astro.props;
const locale = defaultLocale;
const t = translations[locale];

// Resolve the SSR heading/description from the i18n table so the
// initial paint matches the default locale (runtime applyLocale keeps
// them in sync afterwards). Falls back to the passed props.
const resolveKey = (key: string | undefined): string | undefined => {
  if (!key) return undefined;
  const parts = key.split(".");
  let cur: any = t;
  for (const p of parts) cur = cur?.[p];
  return typeof cur === "string" ? cur : undefined;
};
const headingText = resolveKey(headingKey) ?? title.replace("CellScript Registry: ", "");
const descriptionText = resolveKey(descriptionKey) ?? description;
const activeHref =
  active === "submit" ? "/registry/submit" : active === "manage" ? "/registry/manage" : "/registry";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}cellscript-logo.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: light)" href={`${import.meta.env.BASE_URL}cellscript-logo-light.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: dark)" href={`${import.meta.env.BASE_URL}cellscript-logo-dark.png`} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("cellscript-theme");
          const storedLocale = localStorage.getItem("cellscript-locale");
          document.documentElement.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "light";
          document.documentElement.dataset.locale = storedLocale === "zh" ? "zh" : "en";
          document.documentElement.lang = document.documentElement.dataset.locale;
        } catch {
          document.documentElement.dataset.theme = "light";
          document.documentElement.dataset.locale = "en";
          document.documentElement.lang = "en";
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#registry-main" data-i18n="a11y.skipToContent">{t.a11y.skipToContent}</a>
    <SiteHeader page="registry" />
    <main id="registry-main" class="registry-app">
      <header class="registry-topbar" aria-label={t.registry.appLabel} data-i18n-aria-label="registry.appLabel">
        <div>
          <p class="registry-eyebrow" data-i18n="registry.eyebrow">{t.registry.eyebrow}</p>
          <h1 data-registry-heading data-registry-heading-key={headingKey}>{headingText}</h1>
          <p data-registry-description data-registry-description-key={descriptionKey}>{descriptionText}</p>
        </div>
        <a class="registry-button primary registry-topbar-cta" href="/registry/submit" data-i18n="registry.submitPackage">{t.registry.submitPackage}</a>
      </header>

      <nav class="registry-tabs" aria-label={t.registry.sectionsLabel} data-i18n-aria-label="registry.sectionsLabel">
        {registrySections.map((section) => (
          <a
            href={section.href}
            class:list={[
              section.href === activeHref && "active",
              "soon" in section && section.soon && "registry-tabs-soon",
            ]}
            aria-current={section.href === activeHref ? "page" : undefined}
          >
            <span data-i18n={section.i18nKey}>{section.label}</span>
            {"soon" in section && section.soon && section.soonLabel && (
              <span class="registry-tabs-soon-tag" data-i18n={section.soonI18nKey}>{section.soonLabel}</span>
            )}
          </a>
        ))}
      </nav>

      <slot />
    </main>

    <!-- Full i18n message table, embedded so the topbar's language
         toggle can swap every registry string live without a reload. -->
    <script is:inline define:vars={{ i18n: translations }}>
      window.__CELLSCRIPT_I18N__ = i18n;
      window.__CELLSCRIPT_DEFAULT_LOCALE__ = "en";
    </script>

    <script>
      // Registry i18n runtime: mirrors the index/playground layer so the
      // topbar language toggle hot-swaps every [data-i18n] string here.
      const i18nMessages = (window as any).__CELLSCRIPT_I18N__ as any;
      const defaultLocaleName = (window as any).__CELLSCRIPT_DEFAULT_LOCALE__ ?? "en";

      const readLocale = () =>
        document.documentElement.dataset.locale === "zh" ? "zh" : defaultLocaleName;

      const getMessage = (path: string, locale = readLocale()) =>
        path.split(".").reduce((value: any, segment: string) => value?.[segment], i18nMessages?.[locale]);

      const applyLocale = (locale: string) => {
        const nextLocale = locale === "zh" ? "zh" : "en";
        document.documentElement.dataset.locale = nextLocale;
        document.documentElement.lang = nextLocale;
        if (!i18nMessages) return;
        document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((el) => {
          const v = getMessage(el.dataset.i18n ?? "", nextLocale);
          if (typeof v === "string") el.textContent = v;
        });
        document.querySelectorAll<HTMLElement>("[data-i18n-aria-label]").forEach((el) => {
          const v = getMessage(el.dataset.i18nAriaLabel ?? "", nextLocale);
          if (typeof v === "string") el.setAttribute("aria-label", v);
        });
        document.querySelectorAll<HTMLElement>("[data-i18n-placeholder]").forEach((el) => {
          const v = getMessage(el.dataset.i18nPlaceholder ?? "", nextLocale);
          if (typeof v === "string") el.setAttribute("placeholder", v);
        });
        // Re-render the dynamic topbar heading/description and <title>
        // from the active page's registry message (passed via dataset).
        const heading = document.querySelector<HTMLElement>("[data-registry-heading]");
        const headingKey = heading?.dataset.registryHeadingKey;
        if (heading && headingKey) heading.textContent = getMessage(headingKey, nextLocale) ?? heading.textContent;
        const desc = document.querySelector<HTMLElement>("[data-registry-description]");
        const descKey = desc?.dataset.registryDescriptionKey;
        if (desc && descKey) desc.textContent = getMessage(descKey, nextLocale) ?? desc.textContent;
        if (headingKey) document.title = `${getMessage("registry.eyebrow", nextLocale)}: ${getMessage(headingKey, nextLocale)}`;
        try {
          localStorage.setItem("cellscript-locale", nextLocale);
        } catch {
          // Locale switching still works even when storage is unavailable.
        }
      };

      const reapplyRegistryLocale = () => {
        if (!document.querySelector("#registry-main.registry-app")) return;
        applyLocale(readLocale());
      };

      // React to the topbar's locale-change event (it dispatches after
      // updating <html data-locale>) and after Astro swaps page content.
      if (!(window as any).__cellscriptRegistryLayoutLocaleBound) {
        window.addEventListener("cellscript:locale-change", reapplyRegistryLocale);
        document.addEventListener("astro:page-load", reapplyRegistryLocale);
        (window as any).__cellscriptRegistryLayoutLocaleBound = true;
      }
      // Apply the stored locale once on load so a refresh honours it.
      reapplyRegistryLocale();
    </script>

    <script is:inline>
      const flashCopyResult = (button, ok) => {
        const i18n = window.__CELLSCRIPT_I18N__;
        const locale = document.documentElement.dataset.locale === "zh" ? "zh" : "en";
        const get = (path) => path.split(".").reduce((v, k) => (v == null ? v : v[k]), i18n == null ? i18n : i18n[locale]);
        const copiedLabel = (button.dataset.copiedLabel || get("registry.copied") || "Copied");
        const failedLabel = (button.dataset.copyFailedLabel || get("registry.copyFailed") || "Copy failed");
        const revertLabel = (button.dataset.revertLabel || get("registry.copy") || "Copy");
        button.classList.add(ok ? "is-copied" : "is-copy-failed");
        const previous = button.dataset.revertLabel ? button.textContent : revertLabel;
        button.dataset.revertLabel = button.dataset.revertLabel || button.textContent;
        button.textContent = ok ? copiedLabel : failedLabel;
        window.setTimeout(() => {
          button.classList.remove("is-copied", "is-copy-failed");
          button.textContent = previous || revertLabel;
        }, 1400);
      };

      const writeClipboard = async (text) => {
        if (!navigator.clipboard?.writeText) {
          return false;
        }

        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          return false;
        }
      };

      if (!window["__cellscriptRegistryCopyDelegationBound"]) {
        document.addEventListener("click", async (event) => {
          const button = event.target instanceof Element ? event.target.closest("[data-copy-text]") : null;
          if (!button) return;
          const text = button.getAttribute("data-copy-text");
          if (!text) return;
          const ok = await writeClipboard(text);
          flashCopyResult(button, ok);
        });
        window["__cellscriptRegistryCopyDelegationBound"] = true;
      }
    </script>
  </body>
</html>
