---
import RegistryLayout from "../../layouts/RegistryLayout.astro";
import { defaultLocale, translations } from "../../i18n/translations";

const t = translations[defaultLocale];
const description = t.registry.submit.description;
---

<RegistryLayout title="CellScript Registry: Submit" description={description} headingKey="registry.submit.title" descriptionKey="registry.submit.description" active="submit">
  <section class="registry-flow" aria-label={t.registry.nav.submit} data-i18n-aria-label="registry.nav.submit">
    <div class="registry-flow-head">
      <p class="registry-label" data-i18n="registry.submit.builderLabel">{t.registry.submit.builderLabel}</p>
      <h2 data-i18n="registry.submit.builderHeading">{t.registry.submit.builderHeading}</h2>
      <p data-i18n="registry.submit.builderBody">{t.registry.submit.builderBody}</p>
    </div>

    <form class="registry-builder" data-submit-form>
      <div class="registry-builder-grid">
        <label class="registry-builder-field">
          <span data-i18n="registry.submit.namespace">{t.registry.submit.namespace}</span>
          <input class="registry-input" name="namespace" value="" placeholder="dob" autocomplete="off" />
        </label>
        <label class="registry-builder-field">
          <span data-i18n="registry.submit.packageName">{t.registry.submit.packageName}</span>
          <input class="registry-input" name="name" value="" placeholder="evolving-dob-profile-v1" autocomplete="off" />
        </label>
        <label class="registry-builder-field">
          <span data-i18n="registry.submit.sourceRepo">{t.registry.submit.sourceRepo}</span>
          <input class="registry-input" name="source" value="" placeholder="https://github.com/CellScript-Labs/CellScript" autocomplete="off" />
        </label>
        <label class="registry-builder-field">
          <span data-i18n="registry.submit.packageDir">{t.registry.submit.packageDir}</span>
          <input class="registry-input" name="path" value="" placeholder="proposals/evolving-dob/evolving-dob-profile-v1" autocomplete="off" />
        </label>
      </div>
    </form>

    <ol class="registry-steps">
      <li class="registry-step-card">
        <div class="registry-step-copy">
          <span class="registry-step-num">01</span>
          <h3 data-i18n="registry.submit.preflightTitle">{t.registry.submit.preflightTitle}</h3>
          <p data-i18n="registry.submit.preflightBody">{t.registry.submit.preflightBody}</p>
        </div>
        <div class="registry-step-code">
          <code data-submit-preflight>cellc package verify --json && cellc publish --dry-run</code>
          <button class="registry-copy" type="button" data-submit-preflight-copy data-copy-text="cellc package verify --json && cellc publish --dry-run" data-revert-label={t.registry.copy} data-i18n="registry.copy">{t.registry.copy}</button>
        </div>
      </li>
      <li class="registry-step-card">
        <div class="registry-step-copy">
          <span class="registry-step-num">02</span>
          <h3 data-i18n="registry.submit.discoveryTitle">{t.registry.submit.discoveryTitle}</h3>
          <p data-i18n="registry.submit.discoveryBody">{t.registry.submit.discoveryBody}</p>
        </div>
        <div class="registry-step-code">
          <code data-submit-add>cellc auth capability create --principal-id &lt;principal_id&gt; --scope publish:&lt;namespace&gt;/&lt;name&gt; --expires 90d --json &gt; capability-payload.json
cellc auth capability submit --payload capability-payload.json --joyid-signature joyid-signature.json</code>
          <button class="registry-copy" type="button" data-submit-copy data-copy-text="" data-revert-label={t.registry.submit.copyAddCommand} data-i18n="registry.submit.copyAddCommand">{t.registry.submit.copyAddCommand}</button>
        </div>
      </li>
      <li class="registry-step-card">
        <div class="registry-step-copy">
          <span class="registry-step-num">03</span>
          <h3 data-i18n="registry.submit.prTitle">{t.registry.submit.prTitle}</h3>
          <p data-i18n="registry.submit.prBody">{t.registry.submit.prBody}</p>
        </div>
        <div class="registry-step-code">
          <code data-submit-publish>cellc publish</code>
          <button class="registry-copy" type="button" data-submit-publish-copy data-copy-text="cellc publish" data-revert-label={t.registry.copy} data-i18n="registry.copy">{t.registry.copy}</button>
        </div>
      </li>
    </ol>

    <section class="registry-signer" data-capability-signer>
      <div class="registry-flow-head">
        <p class="registry-label">JoyID signer</p>
        <h2>Sign and submit a publisher capability.</h2>
        <p>The challenge below must be the JSON emitted by <code>cellc auth capability create --principal-id &lt;principal_id&gt; --json</code>.</p>
      </div>

      <div class="registry-signer-grid">
        <label class="registry-builder-field registry-signer-api">
          <span>Registry API</span>
          <input class="registry-input" name="registryApi" data-capability-api value="https://api.registry.cellscript.dev" autocomplete="off" />
        </label>
        <label class="registry-builder-field registry-signer-api">
          <span>Connected principal_id</span>
          <input class="registry-input" data-capability-principal readonly placeholder="Connect JoyID to derive principal_id" />
        </label>
        <label class="registry-builder-field">
          <span>Capability payload</span>
          <textarea class="registry-textarea" data-capability-payload spellcheck="false" placeholder='{"protocol":"cellscript-registry-auth-v1",...}'></textarea>
        </label>
        <label class="registry-builder-field">
          <span>JoyID signature</span>
          <textarea class="registry-textarea" data-capability-signature spellcheck="false" readonly></textarea>
        </label>
      </div>

      <div class="registry-signer-actions">
        <button class="registry-button" type="button" data-capability-connect>Connect JoyID</button>
        <button class="registry-button primary" type="button" data-capability-sign>Sign payload</button>
        <button class="registry-button" type="button" data-capability-submit>Submit capability</button>
        <button class="registry-copy" type="button" data-capability-copy-principal data-copy-text="" data-revert-label="Copy principal_id">Copy principal_id</button>
        <button class="registry-copy" type="button" data-capability-copy-signature data-copy-text="" data-revert-label="Copy signature">Copy signature</button>
      </div>
      <output class="registry-signer-status" data-capability-status>JoyID not connected</output>
      <pre class="registry-signer-response" data-capability-response hidden></pre>
    </section>
  </section>

  <script>
    const form = document.querySelector<HTMLFormElement>("[data-submit-form]");
    const preflight = document.querySelector<HTMLElement>("[data-submit-preflight]");
    const preflightCopy = document.querySelector<HTMLElement>("[data-submit-preflight-copy]");
    const add = document.querySelector<HTMLElement>("[data-submit-add]");
    const copy = document.querySelector<HTMLElement>("[data-submit-copy]");
    const publish = document.querySelector<HTMLElement>("[data-submit-publish]");
    const publishCopy = document.querySelector<HTMLElement>("[data-submit-publish-copy]");
    const principalField = document.querySelector<HTMLInputElement>("[data-capability-principal]");

    const value = (name: string) => {
      const input = form?.elements.namedItem(name);
      return input instanceof HTMLInputElement ? input.value.trim() : "";
    };

    const shellQuote = (text: string) => {
      if (!text) return "";
      return /[\s"'$]/.test(text) ? `'${text.replace(/'/g, "'\\''")}'` : text;
    };

    const update = () => {
      const namespace = value("namespace") || "<namespace>";
      const name = value("name") || "<name>";
      const principalId = principalField?.value.trim() || "<principal_id>";
      const path = value("path");
      const cd = path ? `cd ${shellQuote(path)} && ` : "";
      const preflightCommand = `${cd}cellc package verify --json && cellc publish --dry-run`;
      const authCommand = `cellc auth capability create --principal-id ${shellQuote(principalId)} --scope ${shellQuote(`publish:${namespace}/${name}`)} --expires 90d --json > capability-payload.json\ncellc auth capability submit --payload capability-payload.json --joyid-signature joyid-signature.json`;
      const publishCommand = `${cd}cellc publish`;

      if (preflight) preflight.textContent = preflightCommand;
      preflightCopy?.setAttribute("data-copy-text", preflightCommand);
      if (add) add.textContent = authCommand;
      if (publish) publish.textContent = publishCommand;
      copy?.setAttribute("data-copy-text", authCommand);
      publishCopy?.setAttribute("data-copy-text", publishCommand);
    };

    form?.addEventListener("input", update);
    window.addEventListener("cellscript:joyid-connected", update);
    update();
  </script>

  <script>
    import { applyCCCConnectorTheme } from "../../lib/cccConnectorTheme";

    type CapabilitySignature = {
      challenge: string;
      signature: string;
      message?: string;
      pubkey?: string;
      keyType?: string;
      alg?: number | string;
    };

    const apiInput = document.querySelector<HTMLInputElement>("[data-capability-api]");
    const principalInput = document.querySelector<HTMLInputElement>("[data-capability-principal]");
    const payloadInput = document.querySelector<HTMLTextAreaElement>("[data-capability-payload]");
    const signatureOutput = document.querySelector<HTMLTextAreaElement>("[data-capability-signature]");
    const connectButton = document.querySelector<HTMLButtonElement>("[data-capability-connect]");
    const signButton = document.querySelector<HTMLButtonElement>("[data-capability-sign]");
    const submitButton = document.querySelector<HTMLButtonElement>("[data-capability-submit]");
    const copyPrincipalButton = document.querySelector<HTMLButtonElement>("[data-capability-copy-principal]");
    const copySignatureButton = document.querySelector<HTMLButtonElement>("[data-capability-copy-signature]");
    const statusOutput = document.querySelector<HTMLOutputElement>("[data-capability-status]");
    const responseOutput = document.querySelector<HTMLElement>("[data-capability-response]");
    const joyidLogo = `${window.location.origin}${import.meta.env.BASE_URL}cellscript-logo.png`;
    const joyidStorageKey = "cellscript-joyid-connection";

    let cccPromise: Promise<typeof import("@ckb-ccc/connector")> | null = null;
    let activeJoyIdSigner: any | null = null;

    const setCapabilityStatus = (message: string, tone: "idle" | "ok" | "error" = "idle") => {
      if (!statusOutput) return;
      statusOutput.textContent = message;
      statusOutput.dataset.tone = tone;
    };

    const loadCCC = async () => {
      cccPromise ??= import("@ckb-ccc/connector");
      return cccPromise;
    };

    const createJoyIdOnlyController = (ccc: typeof import("@ckb-ccc/connector").ccc) => {
      return new class extends ccc.SignersController {
        async refresh(client: any, onUpdate: (wallets: any[]) => void, configs?: any) {
          await super.refresh(client, (wallets: any[]) => {
            onUpdate(wallets.filter((wallet) => /joyid/i.test(String(wallet.name))));
          }, configs);
        }
      }();
    };

    const canonicalJson = (value: unknown): string => JSON.stringify(sortJson(value));
    const joyidPrincipalContext = "cellscript-registry-joyid-ckb-principal-v1";

    const sortJson = (value: unknown): unknown => {
      if (Array.isArray(value)) return value.map(sortJson);
      if (value && typeof value === "object") {
        const output: Record<string, unknown> = {};
        for (const key of Object.keys(value as Record<string, unknown>).sort()) {
          const item = (value as Record<string, unknown>)[key];
          if (item !== undefined) output[key] = sortJson(item);
        }
        return output;
      }
      return value;
    };

    const sha256Hex = async (value: string): Promise<string> => {
      const hash = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(value));
      return Array.from(new Uint8Array(hash), (byte) => byte.toString(16).padStart(2, "0")).join("");
    };

    const normalizePubkey = (value: string): string => {
      const trimmed = value.trim().toLowerCase();
      return trimmed.startsWith("0x") ? trimmed.slice(2) : trimmed;
    };

    const joyidPrincipalCandidates = async (keyType: string, pubkey: string): Promise<string[]> => {
      const normalized = normalizePubkey(pubkey);
      const candidates = new Set<string>();
      const digest = await sha256Hex(`${joyidPrincipalContext}\n${keyType}\n${normalized}`);
      candidates.add(`0x${digest}`);
      if (/^[0-9a-f]{40,64}$/.test(normalized)) {
        candidates.add(`0x${normalized}`);
      }
      return [...candidates];
    };

    const parsePayload = (): Record<string, unknown> => {
      if (!payloadInput?.value.trim()) {
        throw new Error("Capability payload JSON is required");
      }
      const parsed = JSON.parse(payloadInput.value) as unknown;
      const payload = parsed && typeof parsed === "object" && !Array.isArray(parsed) && "payload" in parsed
        ? (parsed as Record<string, unknown>).payload
        : parsed;
      if (!payload || typeof payload !== "object" || Array.isArray(payload)) {
        throw new Error("Capability payload must be a JSON object");
      }
      return payload as Record<string, unknown>;
    };

    const readSignerIdentity = async (signer: any) => {
      const raw = typeof signer.getIdentity === "function" ? await signer.getIdentity() : undefined;
      if (typeof raw !== "string") return {};
      try {
        const parsed = JSON.parse(raw) as Record<string, unknown>;
        return {
          keyType: typeof parsed.keyType === "string" ? parsed.keyType : undefined,
          publicKey: typeof parsed.publicKey === "string" ? parsed.publicKey : undefined,
        };
      } catch {
        return {};
      }
    };

    const readSignerAddress = async (signer: any): Promise<string | undefined> => {
      if (typeof signer.getInternalAddress === "function") return signer.getInternalAddress();
      if (typeof signer.getBtcAccount === "function") return signer.getBtcAccount();
      return undefined;
    };

    const openJoyIdConnector = async (): Promise<any> => {
      const { ccc } = await loadCCC();
      const connector = document.createElement("ccc-connector") as any;
      connector.name = "CellScript Registry";
      connector.icon = joyidLogo;
      connector.client = new ccc.ClientPublicMainnet();
      connector.preferredNetworks = [{ addressPrefix: "ckb", signerType: ccc.SignerType.CKB, network: "mainnet" }];
      connector.signersController = createJoyIdOnlyController(ccc);
      applyCCCConnectorTheme(connector);

      return new Promise((resolve, reject) => {
        const timeout = window.setTimeout(() => {
          connector.remove();
          reject(new Error("JoyID connection timed out"));
        }, 180000);
        connector.addEventListener("close", async () => {
          window.clearTimeout(timeout);
          try {
            const signer = connector.signer?.signer;
            if (!signer || (typeof signer.isConnected === "function" && !(await signer.isConnected()))) {
              throw new Error("JoyID was not connected");
            }
            connector.remove();
            resolve(signer);
          } catch (error) {
            connector.remove();
            reject(error);
          }
        }, { once: true });
        document.body.appendChild(connector);
        applyCCCConnectorTheme(connector);
      });
    };

    const ensureJoyIdSigner = async () => {
      if (activeJoyIdSigner && (typeof activeJoyIdSigner.isConnected !== "function" || await activeJoyIdSigner.isConnected())) {
        return activeJoyIdSigner;
      }
      setCapabilityStatus("Waiting for JoyID confirmation");
      activeJoyIdSigner = await openJoyIdConnector();
      const address = await readSignerAddress(activeJoyIdSigner);
      const identity = await readSignerIdentity(activeJoyIdSigner);
      if (identity.publicKey && identity.keyType) {
        const [principalId] = await joyidPrincipalCandidates(identity.keyType, identity.publicKey);
        if (principalInput && principalId) principalInput.value = principalId;
        if (principalId) copyPrincipalButton?.setAttribute("data-copy-text", principalId);
      }
      if (address) {
        localStorage.setItem(joyidStorageKey, JSON.stringify({
          principalType: "joyid_ckb",
          address,
          cccIdentity: JSON.stringify({ keyType: identity.keyType, publicKey: identity.publicKey }),
          connectedAt: new Date().toISOString(),
        }));
        window.dispatchEvent(new CustomEvent("cellscript:joyid-connected", { detail: { principalType: "joyid_ckb", address } }));
      }
      setCapabilityStatus(address ? `JoyID connected: ${address}` : "JoyID connected", "ok");
      return activeJoyIdSigner;
    };

    const signCapabilityPayload = async (): Promise<CapabilitySignature> => {
      const signer = await ensureJoyIdSigner();
      const payload = parsePayload();
      const challenge = canonicalJson(payload);
      const rawSignature = await signer.signMessageRaw(challenge);
      let signed: Record<string, unknown>;
      try {
        signed = JSON.parse(String(rawSignature)) as Record<string, unknown>;
      } catch {
        signed = { signature: rawSignature };
      }
      const identity = await readSignerIdentity(signer);
      if (!identity.publicKey || !identity.keyType) {
        throw new Error("JoyID identity did not include public key and key type");
      }
      const principalId = typeof payload["principal_id"] === "string" ? payload["principal_id"].trim().toLowerCase() : "";
      const candidates = await joyidPrincipalCandidates(identity.keyType, identity.publicKey);
      if (!candidates.includes(principalId)) {
        throw new Error(`Payload principal_id does not match this JoyID signer. Use ${candidates[0]}`);
      }
      const signature = typeof signed.signature === "string" ? signed.signature : undefined;
      if (!signature) {
        throw new Error("JoyID did not return a signature");
      }
      const output: CapabilitySignature = {
        challenge,
        signature,
        message: typeof signed.message === "string" ? signed.message : challenge,
        pubkey: identity.publicKey,
        keyType: identity.keyType,
        alg: typeof signed.alg === "number" || typeof signed.alg === "string" ? signed.alg : undefined,
      };
      return output;
    };

    connectButton?.addEventListener("click", async () => {
      connectButton.disabled = true;
      try {
        await ensureJoyIdSigner();
      } catch (error) {
        setCapabilityStatus(error instanceof Error ? error.message : "JoyID connection failed", "error");
      } finally {
        connectButton.disabled = false;
      }
    });

    signButton?.addEventListener("click", async () => {
      signButton.disabled = true;
      try {
        const signature = await signCapabilityPayload();
        if (signatureOutput) signatureOutput.value = JSON.stringify(signature, null, 2);
        copySignatureButton?.setAttribute("data-copy-text", JSON.stringify(signature, null, 2));
        setCapabilityStatus("Capability payload signed", "ok");
      } catch (error) {
        setCapabilityStatus(error instanceof Error ? error.message : "Signing failed", "error");
      } finally {
        signButton.disabled = false;
      }
    });

    submitButton?.addEventListener("click", async () => {
      submitButton.disabled = true;
      try {
        const payload = parsePayload();
        const signature = signatureOutput?.value.trim()
          ? JSON.parse(signatureOutput.value) as CapabilitySignature
          : await signCapabilityPayload();
        if (signatureOutput && !signatureOutput.value.trim()) signatureOutput.value = JSON.stringify(signature, null, 2);
        copySignatureButton?.setAttribute("data-copy-text", JSON.stringify(signature, null, 2));
        const apiBase = (apiInput?.value || "https://api.registry.cellscript.dev").trim().replace(/\/+$/, "");
        const response = await fetch(`${apiBase}/v1/capabilities`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ payload, joyid_signature: signature }),
        });
        const text = await response.text();
        let parsed: unknown;
        try {
          parsed = JSON.parse(text);
        } catch {
          parsed = { response: text };
        }
        if (responseOutput) {
          responseOutput.hidden = false;
          responseOutput.textContent = JSON.stringify(parsed, null, 2);
        }
        if (!response.ok) {
          throw new Error(`Registry API rejected the capability: HTTP ${response.status}`);
        }
        setCapabilityStatus("Capability submitted", "ok");
      } catch (error) {
        setCapabilityStatus(error instanceof Error ? error.message : "Capability submit failed", "error");
      } finally {
        submitButton.disabled = false;
      }
    });
  </script>
</RegistryLayout>
