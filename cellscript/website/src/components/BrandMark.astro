---
const base = import.meta.env.BASE_URL;
---

<span class="brand-mark" aria-hidden="true">
  <img
    class="brand-logo brand-logo-light-theme"
    src={`${base}cellscript-logo-light.png`}
    alt=""
    width="512"
    height="512"
    loading="eager"
    decoding="async"
    draggable="false"
  />
  <img
    class="brand-logo brand-logo-dark-theme"
    src={`${base}cellscript-logo-dark.png`}
    alt=""
    width="512"
    height="512"
    loading="eager"
    decoding="async"
    draggable="false"
  />
</span>
