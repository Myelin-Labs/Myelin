# NovaFungibleXudtCellV0 - Source of Truth Schema (Fungible xUDT Profile v0)
#
# This state cell represents one balance-bearing xUDT object. The v0 profile
# moves the whole balance object between holders; it is not a general ledger.

version: u16
asset_id: Byte32
xudt_type_hash: Byte32
issuer_authority_hash: Byte32
holder_authority_hash: Byte32
amount: u64
status: u8                    # 1 Active, 2 Settled
latest_receipt_hash: Byte32
nonce: u64
expiry: u64
