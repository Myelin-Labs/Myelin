# NovaRwaReceiptCellV0 - Source of Truth Schema (RWA Receipt Profile v0)

version: u16
receipt_id: Byte32
registry_hash: Byte32
asset_commitment_hash: Byte32
document_hash: Byte32
issuer_authority_hash: Byte32
holder_authority_hash: Byte32
amount: u64
status: u8                    # 1 Materialized, 2 Claimed, 3 Settled
latest_receipt_hash: Byte32
nonce: u64
expiry: u64
