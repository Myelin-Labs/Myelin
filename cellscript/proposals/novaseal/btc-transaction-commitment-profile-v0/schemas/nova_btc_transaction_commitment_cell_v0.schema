# NovaBtcTransactionCommitmentCellV0 - Source of Truth Schema

version: u16
seal_id: Byte32
policy_hash: Byte32
committer_authority_hash: Byte32
btc_tx_commitment_hash: Byte32
state_hash: Byte32
status: u8                    # 1 Active, 2 Committed
latest_receipt_hash: Byte32
nonce: u64
expiry: u64
