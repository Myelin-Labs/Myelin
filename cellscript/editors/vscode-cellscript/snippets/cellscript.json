{
  "Action": {
    "prefix": "action",
    "body": [
      "action ${1:name}(${2:input}: ${3:CellType}) -> ${4:output}: ${3:CellType} {",
      "    verification",
      "        require ${5:${4}.owner == ${2}.owner}",
      "}"
    ],
    "description": "Create a CellScript action with a verification section"
  },
  "Lock": {
    "prefix": "lock",
    "body": [
      "lock ${1:name}(protected ${2:cell}: ${3:CellType}, witness ${4:arg}: ${5:Address}, lock_args ${6:owner}: ${7:Address}) -> bool {",
      "    verification",
      "        require ${6} == ${2}.owner",
      "        require ${4} == ${6}",
      "}"
    ],
    "description": "Create a CellScript lock with explicit protected, lock_args, and witness boundaries"
  },
  "Resource": {
    "prefix": "resource",
    "body": [
      "resource ${1:Token} {",
      "    ${2:amount}: ${3:u64}",
      "}"
    ],
    "description": "Create a CellScript resource"
  },
  "Shared": {
    "prefix": "shared",
    "body": [
      "shared ${1:Pool} {",
      "    ${2:reserve}: ${3:u64}",
      "}"
    ],
    "description": "Create a CellScript shared state"
  },
  "Receipt": {
    "prefix": "receipt",
    "body": [
      "receipt ${1:Grant} {",
      "    ${2:beneficiary}: ${3:Address}",
      "}"
    ],
    "description": "Create a CellScript receipt"
  },
  "Effect Attribute": {
    "prefix": "effect",
    "body": [
      "#[effect(${1:Pure})]",
      "#[scheduler_hint(${2:parallel}, estimated_cycles = ${3:1000})]"
    ],
    "description": "Insert effect and scheduler hint attributes"
  },
  "Create With Lock": {
    "prefix": "create",
    "body": [
      "create ${1:output} = ${2:Token} {",
      "    ${3:amount}: ${4:1}",
      "} with_lock(${5:owner})"
    ],
    "description": "Constrain a named output with a lock"
  },
  "Transition": {
    "prefix": "transition",
    "body": [
      "transition ${1:input} -> ${2:output}"
    ],
    "description": "Declare a one-to-one input-output state continuation"
  },
  "Flow": {
    "prefix": "flow",
    "body": [
      "flow ${1:Name} for ${2:Type}.${3:state} {",
      "    ${4:Created} -> ${5:Live};",
      "}"
    ],
    "description": "Declare valid state edges for a state field"
  },
  "Read Parameter": {
    "prefix": "read",
    "body": [
      "read ${1:config}: ${2:Config}"
    ],
    "description": "Declare a read-only action parameter"
  },
  "Witness Parameter": {
    "prefix": "witness",
    "body": [
      "witness ${1:sig}: ${2:Signature}"
    ],
    "description": "Declare a witness-sourced parameter"
  },
  "Require": {
    "prefix": "require",
    "body": [
      "require ${1:condition}"
    ],
    "description": "Fail the current script if a condition is false"
  },
  "Require Block": {
    "prefix": "require-block",
    "body": [
      "require {",
      "    ${1:condition}",
      "}"
    ],
    "description": "Group multiple require conditions in an anonymous block"
  },
  "Preserve": {
    "prefix": "preserve",
    "body": [
      "preserve ${1:output} from ${2:input} {",
      "    ${3:field}",
      "}"
    ],
    "description": "Preserve fields from input to output with require equality sugar"
  },
  "Stdlib Same Lock": {
    "prefix": "std-cell-same-lock",
    "body": [
      "std::cell::same_lock(${1:output}, ${2:input})"
    ],
    "description": "Require output.lock_hash == input.lock_hash"
  },
  "Stdlib Same Type": {
    "prefix": "std-cell-same-type",
    "body": [
      "std::cell::same_type(${1:output}, ${2:input})"
    ],
    "description": "Require output.type_hash == input.type_hash"
  },
  "Stdlib Preserve Lock": {
    "prefix": "std-cell-preserve-lock",
    "body": [
      "std::cell::preserve_lock(${1:output}, ${2:input})"
    ],
    "description": "Require output.lock_hash == input.lock_hash"
  },
  "Stdlib Preserve Type": {
    "prefix": "std-cell-preserve-type",
    "body": [
      "std::cell::preserve_type(${1:output}, ${2:input})"
    ],
    "description": "Require output.type_hash == input.type_hash"
  },
  "Stdlib Preserve Capacity": {
    "prefix": "std-cell-preserve-capacity",
    "body": [
      "std::cell::preserve_capacity(${1:output}, ${2:input})"
    ],
    "description": "Require output.capacity == input.capacity"
  },
  "Stdlib Transfer": {
    "prefix": "std-lifecycle-transfer",
    "body": [
      "std::lifecycle::transfer(${1:input}, ${2:output}, ${3:to}) {",
      "    ${4:field1}",
      "    ${5:field2}",
      "}"
    ],
    "description": "Consume input, lock output, and preserve all output fields"
  },
  "Stdlib Claim": {
    "prefix": "std-receipt-claim",
    "body": [
      "std::receipt::claim(${1:receipt}, ${2:output}, ${3:lock}) {",
      "    ${4:field1}",
      "}"
    ],
    "description": "Consume receipt and create locked output preserving all output fields"
  },
  "Stdlib Settle": {
    "prefix": "std-lifecycle-settle",
    "body": [
      "std::lifecycle::settle(${1:input}, ${2:output}, ${3:lock}) {",
      "    ${4:field1}",
      "}"
    ],
    "description": "Consume input and create locked output preserving all output fields"
  },
  "Stdlib Conserved": {
    "prefix": "std-accounting-conserved",
    "body": [
      "std::accounting::conserved(${1:output}, ${2:input})"
    ],
    "description": "Require output.amount == input.amount"
  }
}
